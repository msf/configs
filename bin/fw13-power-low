#!/bin/bash
# Framework 13 Strix (Ryzen AI 9 HX 370) — power saving profile
#
# Uses active amd_pstate: CPU firmware manages frequency via CPPC,
# guided by EPP hints. Far more efficient than passive mode where
# the OS governor crudely polls and adjusts.

set -uo pipefail

# Active mode — CPU firmware handles freq transitions with hardware telemetry
echo active | sudo tee /sys/devices/system/cpu/amd_pstate/status > /dev/null 2>&1 || true

# 'powersave' in active mode is a pseudo-governor: biases CPU firmware toward efficiency
sudo cpupower frequency-set -g powersave > /dev/null 2>&1

# EPP = power: strongest power-saving hint to CPU firmware
for f in /sys/devices/system/cpu/cpufreq/policy*/energy_performance_preference; do
    echo power | sudo tee "$f" > /dev/null 2>&1 || true
done

# ACPI platform profile: reduces TDP envelope at firmware level
echo low-power | sudo tee /sys/firmware/acpi/platform_profile > /dev/null

# Disable boost — significant power saving, avoids high-voltage spikes
echo 0 | sudo tee /sys/devices/system/cpu/cpufreq/boost > /dev/null

# Cap all cores to 2.0GHz nominal — all-core sustainable, no thermal throttling.
# Predictable throughput for long-running benchmarks.
for f in /sys/devices/system/cpu/cpufreq/policy*/scaling_max_freq; do
    echo 2000000 | sudo tee "$f" > /dev/null 2>&1 || true
done

# GPU: force low performance
echo low | sudo tee /sys/class/drm/card1/device/power_dpm_force_performance_level > /dev/null

# NMI watchdog off — no benefit on laptop, wastes interrupts
echo 0 | sudo tee /proc/sys/kernel/nmi_watchdog > /dev/null

# USB autosuspend on
echo 1 | sudo tee /sys/module/usbcore/parameters/autosuspend > /dev/null

# Aggressive writeback delay and laptop mode (reduces disk wakeups)
echo 5 | sudo tee /proc/sys/vm/laptop_mode > /dev/null
echo 1500 | sudo tee /proc/sys/vm/dirty_writeback_centisecs > /dev/null

# controlled by kanshi Display: drop to 60Hz
# swaymsg output eDP-1 mode 2880x1920@60Hz > /dev/null 2>&1 || true
